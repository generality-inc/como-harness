{
  "resource": "post",
  "action": "comments",
  "method": "GET",
  "upstream_path": "/linkedin/post-comments",
  "como_path": "/v1/ghost/post-comments",
  "summary": "Retrieve comments on a post by URL.",
  "query_params": [
    {"name": "post", "type": "string", "required": true, "description": "URL of the post"},
    {"name": "sortBy", "type": "string", "required": false, "description": "Sort comments. Supported: 'relevance', 'date'"},
    {"name": "page", "type": "integer", "required": false, "description": "Page number for pagination (default: 1)"},
    {"name": "paginationToken", "type": "string", "required": false, "description": "Required only if sortBy is 'relevance' and page > 1"}
  ],
  "headers": [],
  "request_body": null,
  "response_schema": {
    "elements": [{
      "id": "string",
      "linkedinUrl": "string",
      "commentary": "string",
      "createdAt": "string (date-time)",
      "numComments": "integer",
      "numShares": "integer|null",
      "numImpressions": "integer|null",
      "reactionTypeCounts": [{"type": "enum (LIKE|EMPATHY|PRAISE|INTEREST|MAYBE)", "count": "integer"}],
      "postId": "string",
      "actor": {
        "id": "string", "name": "string", "linkedinUrl": "string", "position": "string", "pictureUrl": "string",
        "picture": {"url": "string", "width": "integer", "height": "integer", "expiresAt": "integer"},
        "author": "boolean"
      },
      "createdAtTimestamp": "integer (int64)",
      "pinned": "boolean",
      "contributed": "boolean",
      "edited": "boolean"
    }],
    "pagination": {
      "totalPages": "integer", "totalElements": "integer", "pageNumber": "integer",
      "previousElements": "integer", "pageSize": "integer", "paginationToken": "string|null"
    },
    "status": "string",
    "error": "string"
  },
  "error_schema": {"error": "integer", "message": "string"},
  "notes": "When sortBy='relevance' and page > 1, paginationToken is required."
}
