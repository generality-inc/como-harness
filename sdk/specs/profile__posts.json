{
  "resource": "profile",
  "action": "posts",
  "method": "GET",
  "como_path": "/v1/ghost/profile-posts",
  "summary": "Retrieve posts published by a profile using URL, ID, or public identifier.",
  "query_params": [
    {
      "name": "profile",
      "type": "string",
      "required": false,
      "description": "Filter posts by author's profile URL"
    },
    {
      "name": "profileId",
      "type": "string",
      "required": false,
      "description": "Filter posts by author's profile ID (faster than URL)"
    },
    {
      "name": "profilePublicIdentifier",
      "type": "string",
      "required": false,
      "description": "Filter posts by author's profile public identifier (URL suffix)"
    },
    {
      "name": "postedLimit",
      "type": "string",
      "required": false,
      "description": "Filter posts by max posted date: '24h', 'week', 'month' (client-side filtering)"
    },
    {
      "name": "historyLimit",
      "type": "string",
      "required": false,
      "description": "Post-filter by date: '1h', '24h', 'week', 'month', '3months', '6months', 'year'"
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number for pagination (default: 1)"
    },
    {
      "name": "paginationToken",
      "type": "string",
      "required": false,
      "description": "Required if returned by previous page for continued pagination"
    }
  ],
  "headers": [],
  "request_body": null,
  "response_schema": {
    "elements": [
      {
        "id": "string",
        "content": "string",
        "linkedinUrl": "string",
        "author": {
          "id": "string",
          "urn": "string",
          "publicIdentifier": "string",
          "universalName": "string",
          "name": "string",
          "linkedinUrl": "string",
          "type": "boolean",
          "info": "boolean",
          "website": "boolean",
          "websiteLabel": "boolean",
          "avatar": {
            "url": "string",
            "width": "integer",
            "height": "integer",
            "expiresAt": "integer"
          }
        },
        "postedAt": {
          "timestamp": "integer",
          "date": "string",
          "postedAgoShort": "string",
          "postedAgoText": "string"
        },
        "postImages": [
          {
            "url": "string",
            "width": "integer",
            "height": "integer",
            "expiresAt": "integer"
          }
        ],
        "postVideo": {
          "thumbnailUrl": "string",
          "videoUrl": "string"
        },
        "article": {
          "title": "string",
          "subtitle": "string",
          "link": "string",
          "linkLabel": "string",
          "description": "string",
          "image": {
            "url": "string",
            "width": "integer",
            "height": "integer",
            "expiresAt": "integer"
          }
        },
        "repostId": "string|null",
        "repost": "object",
        "repostedBy": {
          "publicIdentifier": "string",
          "name": "string",
          "linkedinUrl": "string"
        },
        "newsletterUrl": "string",
        "newsletterTitle": "string",
        "socialContent": {
          "hideCommentsCount": "boolean",
          "hideReactionsCount": "boolean",
          "hideSocialActivityCounts": "boolean",
          "hideShareAction": "boolean",
          "hideSendAction": "boolean",
          "hideRepostsCount": "boolean",
          "hideViewsCount": "boolean",
          "hideReactAction": "boolean",
          "hideCommentAction": "boolean",
          "shareUrl": "string",
          "showContributionExperience": "boolean",
          "showSocialDetail": "boolean"
        },
        "engagement": {
          "likes": "integer",
          "comments": "integer",
          "shares": "integer",
          "reactions": [
            {
              "type": "string",
              "count": "integer"
            }
          ]
        }
      }
    ],
    "pagination": {
      "totalPages": "integer",
      "totalElements": "integer",
      "pageNumber": "integer",
      "previousElements": "integer",
      "pageSize": "integer",
      "paginationToken": "string|null"
    },
    "cost": {
      "amount": "string",
      "currency": "string"
    }
  },
  "error_schema": {
    "error": "integer",
    "message": "string"
  },
  "notes": "Requires one of: profile, profileId, or profilePublicIdentifier. Upstream pagination totals may be inaccurate when postedLimit is applied. Use paginationToken if returned for accurate next-page."
}
