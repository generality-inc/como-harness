{
  "resource": "company",
  "action": "search",
  "method": "GET",
  "upstream_path": "/linkedin/company-search",
  "como_path": "/v1/ghost/company-search",
  "summary": "Retrieve companies matching specified search criteria with optional filtering.",
  "query_params": [
    {"name": "search", "type": "string", "required": false, "description": "Keywords to search for in company names"},
    {"name": "location", "type": "string", "required": false, "description": "Filter companies by location"},
    {"name": "geoId", "type": "string", "required": false, "description": "Filter by location as Geo ID; overrides location parameter"},
    {"name": "companySize", "type": "string", "required": false, "description": "Filter by company size (comma-separated). Supported: 1-10, 11-50, 51-200, 201-500, 501-1000, 1001-5000, 5001-10000, 10001+"},
    {"name": "industryId", "type": "string", "required": false, "description": "Filter by industry ID (comma-separated values)"},
    {"name": "page", "type": "integer", "required": false, "description": "Page number for pagination (default: 1)"}
  ],
  "headers": [],
  "request_body": null,
  "response_schema": {
    "elements": [{
      "id": "string",
      "name": "string",
      "industries": "string",
      "location": {"linkedinText": "string"},
      "followers": "string",
      "summary": "string",
      "logo": "string",
      "linkedinUrl": "string",
      "universalName": "string"
    }],
    "pagination": {
      "totalPages": "integer", "totalElements": "integer", "pageNumber": "integer",
      "previousElements": "integer", "pageSize": "integer", "paginationToken": "string|null"
    },
    "status": "string",
    "error": "string",
    "query": {"search": "string", "location": "string", "geoId": "string", "companySize": "string"},
    "cost": {"amount": "string", "currency": "string"}
  },
  "error_schema": {"error": "integer", "message": "string"},
  "notes": "geoId overrides location string. Use geo search endpoint to resolve ambiguous locations. Pagination via page and paginationToken."
}
