{
  "resource": "company",
  "action": "posts",
  "method": "GET",
  "upstream_path": "/linkedin/company-posts",
  "como_path": "/v1/ghost/company-posts",
  "summary": "Retrieve posts published by a company using URL, ID, or universal name.",
  "query_params": [
    {"name": "company", "type": "string", "required": false, "description": "Filter posts by company URL"},
    {"name": "companyId", "type": "string", "required": false, "description": "Filter posts by company ID (faster than URL-based search)"},
    {"name": "companyUniversalName", "type": "string", "required": false, "description": "Filter posts by company universal name (final URL segment)"},
    {"name": "postedLimit", "type": "string", "required": false, "description": "Client-side filter by posted date. Values: '24h', 'week', 'month'"},
    {"name": "scrapePostedLimit", "type": "string", "required": false, "description": "Server-side post-filter by date. Values: '1h', '24h', 'week', 'month', '3months', '6months', 'year'"},
    {"name": "page", "type": "integer", "required": false, "description": "Page number for pagination (default: 1)"},
    {"name": "paginationToken", "type": "string", "required": false, "description": "Token from previous page response for continued pagination"}
  ],
  "headers": [],
  "request_body": null,
  "response_schema": {
    "elements": [{
      "id": "string",
      "content": "string",
      "linkedinUrl": "string",
      "author": {
        "id": "string", "urn": "string", "publicIdentifier": "string", "universalName": "string",
        "name": "string", "linkedinUrl": "string",
        "type": "boolean", "info": "boolean", "website": "boolean", "websiteLabel": "boolean",
        "avatar": {"url": "string", "width": "integer", "height": "integer", "expiresAt": "integer"}
      },
      "postedAt": {"timestamp": "integer", "date": "string", "postedAgoShort": "string", "postedAgoText": "string"},
      "postImages": [{"url": "string", "width": "integer", "height": "integer", "expiresAt": "integer"}],
      "postVideo": {"thumbnailUrl": "string", "videoUrl": "string"},
      "article": {
        "title": "string", "subtitle": "string", "link": "string", "linkLabel": "string", "description": "string",
        "image": {"url": "string", "width": "integer", "height": "integer", "expiresAt": "integer"}
      },
      "repostId": "string",
      "repost": "object",
      "repostedBy": {"publicIdentifier": "string", "name": "string", "linkedinUrl": "string"},
      "newsletterUrl": "string",
      "newsletterTitle": "string",
      "socialContent": {
        "hideCommentsCount": "boolean", "hideReactionsCount": "boolean", "hideSocialActivityCounts": "boolean",
        "hideShareAction": "boolean", "hideSendAction": "boolean", "hideRepostsCount": "boolean",
        "hideViewsCount": "boolean", "hideReactAction": "boolean", "hideCommentAction": "boolean",
        "shareUrl": "string", "showContributionExperience": "boolean", "showSocialDetail": "boolean"
      },
      "engagement": {
        "likes": "integer", "comments": "integer", "shares": "integer",
        "reactions": [{"type": "string", "count": "integer"}]
      }
    }],
    "pagination": {
      "totalPages": "integer", "totalElements": "integer", "pageNumber": "integer",
      "previousElements": "integer", "pageSize": "integer", "paginationToken": "string"
    },
    "status": "string",
    "error": "string",
    "query": {"search": "string", "profileId": "string", "companyId": "string", "postedLimit": "string", "sortBy": "string", "page": "integer"},
    "cost": {"amount": "string", "currency": "string"}
  },
  "error_schema": {"error": "integer", "message": "string"},
  "notes": "Requires one of: company URL, companyId, or companyUniversalName. postedLimit is client-side and may affect pagination accuracy; scrapePostedLimit is server-side post-fetch."
}
