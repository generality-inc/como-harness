{
  "resource": "group",
  "action": "search",
  "method": "GET",
  "como_path": "/v1/ghost/group-search",
  "summary": "Retrieve a list of groups matching specified search criteria with pagination support.",
  "query_params": [
    {
      "name": "search",
      "type": "string",
      "required": false,
      "description": "Keywords to search for"
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number for pagination (default: 1)"
    }
  ],
  "headers": [],
  "request_body": null,
  "response_schema": {
    "elements": [
      {
        "id": "string",
        "linkedinUrl": "string|null",
        "name": "string|null",
        "members": "string|null",
        "summary": "string|null",
        "picture": "string|null",
        "primaryActions": [
          {
            "label": "string|null",
            "value": "string|null"
          }
        ]
      }
    ],
    "pagination": {
      "totalPages": "integer",
      "totalElements": "integer",
      "pageNumber": "integer",
      "previousElements": "integer",
      "pageSize": "integer",
      "paginationToken": "string|null"
    },
    "cost": {
      "amount": "string",
      "currency": "string"
    }
  },
  "error_schema": {
    "error": "integer",
    "message": "string"
  },
  "notes": "All group fields except id are nullable."
}
