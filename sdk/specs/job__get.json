    {"name": "url", "type": "string", "required": false, "description": "URL of the job"}
  ],
  "headers": [],
  "request_body": null,
  "response_schema": {
    "element": {
      "id": "string",
      "title": "string",
      "linkedinUrl": "string",
      "jobState": "string",
      "postedDate": "string (date-time)",
      "descriptionText": "string",
      "descriptionHtml": "string",
      "location": {
        "linkedinText": "string",
        "postalAddress": "string|null",
        "parsed": {
