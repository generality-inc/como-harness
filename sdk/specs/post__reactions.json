{
  "resource": "post",
  "action": "reactions",
  "method": "GET",
  "como_path": "/v1/ghost/post-reactions",
  "summary": "Retrieve reactions to a post by URL, including reaction type and reactor profile information.",
  "query_params": [
    {
      "name": "post",
      "type": "string",
      "required": true,
      "description": "URL of the post"
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number for pagination (default: 1)"
    }
  ],
  "headers": [],
  "request_body": null,
  "response_schema": {
    "elements": [
      {
        "id": "string",
        "reactionType": "string",
        "postId": "string",
        "actor": {
          "id": "string",
          "name": "string",
          "linkedinUrl": "string",
          "position": "string",
          "pictureUrl": "string",
          "picture": {
            "url": "string",
            "width": "integer",
            "height": "integer",
            "expiresAt": "integer"
          }
        }
      }
    ],
    "pagination": {
      "totalPages": "integer",
      "totalElements": "integer",
      "pageNumber": "integer",
      "previousElements": "integer",
      "pageSize": "integer",
      "paginationToken": "string|null"
    },
    "cost": {
      "amount": "string",
      "currency": "string"
    }
  },
  "error_schema": {
    "error": "integer",
    "message": "string"
  },
  "notes": "Profile URLs in reactions may be returned in ID form without public slugs."
}
