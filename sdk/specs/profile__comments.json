{
  "resource": "profile",
  "action": "comments",
  "method": "GET",
  "upstream_path": "/linkedin/profile-comments",
  "como_path": "/v1/ghost/profile-comments",
  "summary": "Retrieve comments made by a profile user.",
  "query_params": [
    {"name": "profile", "type": "string", "required": false, "description": "URL of the profile"},
    {"name": "profileId", "type": "string", "required": false, "description": "Profile ID. Faster than URL lookup"},
    {"name": "postedLimit", "type": "string", "required": false, "description": "Filter posts by max posted date. Values: '24h', 'week', 'month'"},
    {"name": "page", "type": "integer", "required": false, "description": "Page number for pagination (default: 1)"},
    {"name": "paginationToken", "type": "string", "required": false, "description": "Required for pages > 1. Token from previous page response"}
  ],
  "headers": [],
  "request_body": null,
  "response_schema": {
    "elements": [{
      "id": "string",
      "linkedinUrl": "string",
      "commentary": "string",
      "createdAt": "string (date-time)",
      "createdAtTimestamp": "integer (int64)",
      "numComments": "integer",
      "numShares": "integer|null",
      "numImpressions": "integer|null",
      "reactionTypeCounts": [{"type": "enum (LIKE|EMPATHY|PRAISE|INTEREST|MAYBE)", "count": "integer"}],
      "postId": "string",
      "pinned": "boolean",
      "contributed": "boolean",
      "edited": "boolean",
      "actor": {
        "id": "string",
        "name": "string",
        "linkedinUrl": "string",
        "position": "string",
        "pictureUrl": "string",
        "picture": {"url": "string", "width": "integer", "height": "integer", "expiresAt": "integer"},
        "author": "boolean"
      }
    }],
    "pagination": {
      "totalPages": "integer", "totalElements": "integer", "pageNumber": "integer",
      "previousElements": "integer", "pageSize": "integer", "paginationToken": "string|null"
    },
    "status": "string",
    "error": "string",
    "cost": {"amount": "string", "currency": "string"}
  },
  "error_schema": {"error": "integer", "message": "string"},
  "notes": "Requires one of: profile, profileId. profileId is faster. paginationToken required for pages > 1."
}
